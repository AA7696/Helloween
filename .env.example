# Copy this file to `.env.local` and fill in real values. Do NOT commit `.env.local`.

# MongoDB connection string (e.g. MongoDB Atlas)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Secret used to sign JWT session cookies — use a long random string
JWT_SECRET=replace-with-a-long-random-secret

# Seeded admin account (used by `npm run seed`)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Razorpay TEST keys — leave blank to use the built-in mock payment fallback
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
